---
const { number, title, description, tone } = Astro.props;

const parsedNumber = Number.parseInt(String(number || ""), 10);
const intensity = Number.isNaN(parsedNumber)
  ? Math.min(Math.max(Number(tone) || 1, 1), 3)
  : Math.min(Math.max(parsedNumber, 1), 3);

const tonePalette = [
  {
    border: "border-sky-200/70",
    background: "bg-slate-50/60",
    number: "text-sky-600 group-hover:text-sky-500",
    accent: "bg-sky-400",
  },
  {
    border: "border-sky-400/70",
    background: "bg-slate-100/60",
    number: "text-sky-700 group-hover:text-sky-600",
    accent: "bg-sky-600",
  },
  {
    border: "border-sky-600/80",
    background: "bg-slate-200/60",
    number: "text-sky-800 group-hover:text-sky-700",
    accent: "bg-sky-800",
  },
];

const toneClasses = tonePalette[intensity - 1] || tonePalette[0];
---

<article
  class:list={[
    "group relative border-l-2 p-12 transition-colors",
    toneClasses.border,
    toneClasses.background,
  ]}>
  <span
    class:list={[
      "mb-8 block font-headline text-5xl font-black transition-colors",
      toneClasses.number,
    ]}>
    {number}
  </span>
  <h3
    class="mb-4 font-headline text-2xl font-bold tracking-tight text-primary uppercase">
    {title}
  </h3>
  <p class="mb-8 font-light text-on-surface-variant">{description}</p>
  <div
    class:list={[
      "absolute bottom-0 left-0 h-1 w-0 transition-all duration-500 group-hover:w-full",
      toneClasses.accent,
    ]}>
  </div>
  <div
    class="absolute bottom-6 right-6 text-sm underline text-end opacity-0 duration-600 group-hover:opacity-100 group-hover:translate-y-1">
    <a href="#contacto" title="Iniciar mi arquitectura" class="block p-4">
      Iniciar mi Arquitectura &gt;
    </a>
  </div>
</article>
