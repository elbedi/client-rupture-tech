---
const {
  label,
  href,
  variant = "primary",
  className = "",
  ariaLabel,
  title,
  openContactModal = false,
} = Astro.props;

const baseClass =
  "inline-flex items-center justify-center px-8 py-5 font-headline text-sm font-bold uppercase tracking-widest transition-all duration-300 cursor-pointer";

const variants = {
  primary: "relative bg-primary text-on-primary hover:translate-x-1",
  ghost:
    "border border-outline-variant text-primary hover:bg-surface-container-high",
};

const variantClass = variant === "ghost" ? variants.ghost : variants.primary;
---

{
  href ? (
    <a
      href={href}
      aria-label={ariaLabel || label}
      title={title || label}
      data-open-contact-modal={openContactModal ? "true" : undefined}
      class:list={[baseClass, variantClass, className]}>
      <span>{label}</span>
      <slot />
    </a>
  ) : (
    <button
      type="button"
      aria-label={ariaLabel || label}
      title={title || label}
      data-open-contact-modal={openContactModal ? "true" : undefined}
      class:list={[baseClass, variantClass, className]}>
      <span>{label}</span>
      <slot />
    </button>
  )
}
