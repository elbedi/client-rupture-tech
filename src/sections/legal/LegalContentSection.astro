---
const { legal } = Astro.props;

interface LegalSection {
  title: string;
  paragraphs?: string[];
  bullets?: string[];
}

const sections: LegalSection[] = Array.isArray(legal?.sections)
  ? legal.sections
  : [];
const hasSecondaryIntro =
  typeof legal?.introSecondary === "string" &&
  legal.introSecondary.trim().length > 0;
---

<section class="bg-surface-container-low pt-28 pb-20">
  <div class="mx-auto w-9/10 max-w-5xl">
    <header class="rounded-3xl bg-primary px-8 py-12 text-on-primary md:px-12">
      <p class="text-xs font-bold tracking-[0.24em] text-cyan-300 uppercase">
        Legal
      </p>
      <h1
        class="mt-4 font-headline text-4xl font-extrabold tracking-tight md:text-5xl">
        {legal.pageTitle}
      </h1>
      <p class="mt-4 text-sm text-slate-300 md:text-base">
        Última actualización: {legal.updatedAt}
      </p>
    </header>

    <article
      class="mt-10 rounded-3xl border border-slate-200 bg-white px-7 py-10 md:px-12 md:py-14">
      <div
        class="space-y-5 text-sm leading-relaxed text-slate-700 md:text-base">
        <p>{legal.intro}</p>
        {hasSecondaryIntro && <p>{legal.introSecondary}</p>}
      </div>

      <div class="mt-12 space-y-12">
        {
          sections.map((section: LegalSection) => (
            <section>
              <h2 class="font-headline text-2xl font-bold tracking-tight text-slate-900 md:text-3xl">
                {section.title}
              </h2>

              <div class="mt-5 space-y-4 text-sm leading-relaxed text-slate-700 md:text-base">
                {(section.paragraphs || []).map((paragraph: string) => (
                  <p>{paragraph}</p>
                ))}
              </div>

              {(section.bullets || []).length > 0 && (
                <ul class="mt-5 space-y-3 text-sm leading-relaxed text-slate-700 md:text-base">
                  {(section.bullets || []).map((bullet: string) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-secondary" />
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}
            </section>
          ))
        }
      </div>
    </article>
  </div>
</section>
