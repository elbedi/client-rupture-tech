---
import LimitContainer from "@/components/common/LimitContainer.jsx";

const { philosophy } = Astro.props;
---

<section id="filosofia" class="bg-white py-32">
  <LimitContainer className="px-6 lg:px-8">
    <div class="flex flex-col gap-20 lg:flex-row">
      <div class="lg:w-1/3">
        <div class="sticky top-40">
          <p
            class="mb-4 block text-xs font-bold tracking-[0.3em] text-secondary uppercase">
            {philosophy.kicker}
          </p>
          <h2
            class="font-headline text-4xl leading-none font-extrabold tracking-tighter text-primary uppercase">
            {philosophy.title}
          </h2>
        </div>
      </div>

      <div class="lg:w-2/3">
        <div
          class="prose prose-xl leading-relaxed font-light text-on-surface-variant">
          {
            philosophy.paragraphs.map((paragraph) => (
              <p class="mb-8">{paragraph}</p>
            ))
          }

          <div class="mt-16 grid grid-cols-1 gap-12 md:grid-cols-2">
            {
              philosophy.pillars.map((pillar) => (
                <article class="border-l-4 border-secondary bg-surface-container-low p-8">
                  <h3 class="mb-4 font-headline font-bold text-primary">
                    {pillar.title}
                  </h3>
                  <p class="text-sm">{pillar.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </LimitContainer>
</section>
