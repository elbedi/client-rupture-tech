---
import LimitContainer from "@/components/common/LimitContainer.jsx";

const { howWeDoIt } = Astro.props;
---

<section id="como-lo-hacemos" class="text-slate-900">
  <LimitContainer>
    <div class="relative flow-root">
      <div
        class="absolute top-0 right-0 bg-sky-400 h-full w-2/4 -z-1 opacity-15"
        style="clip-path: polygon(0 0%, 60% 0, 100% 100%, 40% 100%)">
      </div>
      <div class="mt-30" data-reveal="philosophy-intro">
        <p
          class="mb-4 text-xs font-bold tracking-[0.28em] text-sky-700 uppercase">
          {howWeDoIt.kicker}
        </p>
        <h2
          class="font-headline text-4xl leading-tight font-extrabold tracking-tight sm:text-5xl">
          {howWeDoIt.title}
        </h2>
        <p
          class="mt-7 max-w-xl text-base leading-relaxed text-slate-600 sm:text-lg">
          {howWeDoIt.description}
        </p>
      </div>
      <div class="mt-20 flex gap-5 pb-30 max-md:flex-col">
        {
          howWeDoIt.steps.map(
            (step: { number: string; title: string; description: string }) => (
              <article
                data-reveal="step"
                class="group rounded-2xl border border-slate-200 bg-white p-7 transition-colors duration-300 hover:border-sky-300 hover:bg-sky-50/40">
                <div class="mb-4 inline-flex items-center rounded-full border border-slate-300 px-3 py-1 font-mono text-xs tracking-[0.2em] text-sky-700">
                  {step.number}
                </div>
                <h3 class="font-headline text-xl leading-tight font-bold text-slate-900">
                  {step.title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base">
                  {step.description}
                </p>
              </article>
            ),
          )
        }
      </div>
    </div>
  </LimitContainer>
</section>
