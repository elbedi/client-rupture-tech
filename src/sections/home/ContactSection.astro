---
import LimitContainer from "@/components/common/LimitContainer.jsx";

const { contact = {}, services = [] } = Astro.props;

const serviceOptions: string[] = services.length
  ? services
  : [
      "Arquitectura cloud",
      "Desarrollo de software",
      "Ciberseguridad",
      "Consultoría tecnológica",
      "Otro",
    ];
---

<section
  id="contacto"
  class="relative overflow-hidden bg-surface py-20 lg:py-28">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-14 right-[8%] h-48 w-48 bg-sky-200/40 blur-3xl">
    </div>
    <div class="absolute bottom-0 left-0 h-56 w-56 bg-cyan-300/30 blur-3xl">
    </div>
    <div
      class="absolute inset-y-0 right-0 w-[55%] max-lg:w-full bg-sky-100/35"
      style="clip-path: polygon(18% 0, 100% 0, 100% 100%, 0 100%);">
    </div>
  </div>

  <LimitContainer className="relative z-10">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-stretch">
      <div class="lg:col-span-5">
        <p
          class="mb-4 font-headline text-xs font-bold tracking-[0.22em] text-sky-700 uppercase">
          Agenda tu consulta
        </p>
        <h2
          class="max-w-md font-headline text-4xl font-extrabold leading-[0.95] tracking-tight text-primary lg:text-5xl">
          Diseñemos la arquitectura digital de tu negocio
        </h2>
        <p
          class="mt-6 max-w-lg text-base leading-relaxed text-slate-700 lg:text-lg">
          Comparte tus retos operativos y objetivos. Te devolvemos una ruta
          clara con prioridades, alcance y siguientes pasos accionables.
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          <div class="border border-sky-200 bg-white/70 p-4 shadow-sm">
            <p
              class="text-[10px] font-bold tracking-[0.2em] text-sky-700 uppercase">
              Correo
            </p>
            <p class="mt-2 text-sm font-semibold text-slate-900">
              {contact.email || "contacto@rupture-tech.com"}
            </p>
          </div>
          <div class="border border-sky-200 bg-white/70 p-4 shadow-sm">
            <p
              class="text-[10px] font-bold tracking-[0.2em] text-sky-700 uppercase">
              Teléfono
            </p>
            <p class="mt-2 text-sm font-semibold text-slate-900">
              {contact.phone || "+52 990 309 7476"}
            </p>
          </div>
          <div class="border border-sky-200 bg-white/70 p-4 shadow-sm">
            <p
              class="text-[10px] font-bold tracking-[0.2em] text-sky-700 uppercase">
              Cobertura
            </p>
            <p class="mt-2 text-sm font-semibold text-slate-900">
              México y LATAM
            </p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div
          class="relative border border-sky-200 bg-white/85 p-6 shadow-[0_40px_70px_-45px_rgba(2,132,199,0.9)] backdrop-blur-sm sm:p-8 lg:p-10">
          <div
            class="mb-6 flex items-center justify-between gap-4 border-b border-sky-100 pb-4">
            <h3
              class="font-headline text-2xl font-extrabold tracking-tight text-slate-900">
              Agendar consulta estratégica
            </h3>
            <span
              class="hidden bg-sky-700 px-3 py-1 text-[10px] font-bold tracking-[0.16em] text-white uppercase sm:inline-block">
              Respuesta en 24h
            </span>
          </div>

          <form
            class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5"
            id="agenda-consulta-form">
            <label class="flex flex-col gap-2 sm:col-span-1">
              <span
                class="text-xs font-semibold tracking-wide text-slate-700 uppercase"
                >Nombre</span
              >
              <input
                type="text"
                name="name"
                placeholder="Tu nombre"
                class="h-12 border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-sky-500"
              />
            </label>

            <label class="flex flex-col gap-2 sm:col-span-1">
              <span
                class="text-xs font-semibold tracking-wide text-slate-700 uppercase"
                >Empresa</span
              >
              <input
                type="text"
                name="company"
                placeholder="Nombre de tu empresa"
                class="h-12 border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-sky-500"
              />
            </label>

            <label class="flex flex-col gap-2 sm:col-span-1">
              <span
                class="text-xs font-semibold tracking-wide text-slate-700 uppercase"
                >Teléfono</span
              >
              <input
                type="tel"
                name="phone"
                placeholder="+52 55 1234 5678"
                class="h-12 border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-sky-500"
              />
            </label>

            <label class="flex flex-col gap-2 sm:col-span-1">
              <span
                class="text-xs font-semibold tracking-wide text-slate-700 uppercase"
                >Correo</span
              >
              <input
                type="email"
                name="email"
                placeholder="contacto@rupture-tech.com"
                class="h-12 border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-sky-500"
              />
            </label>

            <label class="flex flex-col gap-2 sm:col-span-2">
              <span
                class="text-xs font-semibold tracking-wide text-slate-700 uppercase"
                >Servicio de interés</span
              >
              <select
                name="service"
                class="h-12 border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none transition-colors focus:border-sky-500">
                <option value="" disabled selected
                  >Selecciona un servicio</option
                >
                {
                  serviceOptions.map((service) => (
                    <option value={service} class="text-slate-900">
                      {service}
                    </option>
                  ))
                }
              </select>
            </label>

            <label class="flex flex-col gap-2 sm:col-span-2">
              <span
                class="text-xs font-semibold tracking-wide text-slate-700 uppercase"
                >Objetivo principal</span
              >
              <textarea
                name="goal"
                rows="4"
                placeholder="Cuéntanos qué proceso quieres optimizar o qué reto quieres resolver."
                class="border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-sky-500"
              ></textarea>
            </label>

            <label
              class="sm:col-span-2 flex items-start gap-3 text-xs text-slate-600">
              <input
                type="checkbox"
                name="legalConsent"
                required
                class="mt-0.5 h-4 w-4 border border-slate-300 accent-sky-700"
              />
              <span>
                Acepto el <a href="/legal/privacy" class="underline"
                  >Aviso de Privacidad</a
                > y los <a href="/legal/terms" class="underline"
                  >Términos y Condiciones</a
                >.
              </span>
            </label>

            <div
              class="sm:col-span-2 mt-2 flex flex-wrap items-center justify-between gap-4">
              <p class="text-xs text-slate-500">
                Al enviar, aceptas que nuestro equipo te contacte por correo o
                teléfono.
              </p>
              <button
                type="submit"
                class="inline-flex h-12 items-center justify-center bg-sky-700 px-7 font-headline text-xs font-bold tracking-[0.16em] text-white uppercase transition-transform duration-200 hover:scale-[0.98] cursor-pointer">
                Agendar consulta
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </LimitContainer>
</section>
