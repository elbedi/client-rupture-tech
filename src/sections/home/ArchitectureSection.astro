---
import LimitContainer from "@/components/common/LimitContainer.jsx";
import NumberedFeatureCard from "@/components/common/NumberedFeatureCard.astro";

const { architecture, theProblem } = Astro.props;
---

<section id="arquitectura" class="relative overflow-hidden bg-white py-32">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div
      class="absolute -left-20 top-24 h-72 w-72 rounded-full bg-secondary/10 blur-3xl">
    </div>
    <div
      class="absolute -right-20 bottom-16 h-72 w-72 rounded-full bg-slate-900/10 blur-3xl">
    </div>
  </div>

  <LimitContainer className="relative z-10 px-6 lg:px-8">
    <div
      class="relative mb-20 overflow-hidden rounded-3xl border border-secondary/40 bg-primary px-8 py-10 shadow-2xl md:px-10 md:py-12">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-16 -right-12 h-52 w-52 rounded-full bg-secondary/20 blur-3xl">
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-24 -left-16 h-60 w-60 rounded-full bg-white/10 blur-3xl">
      </div>

      <div
        class="relative grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div>
          <p
            class="mb-4 font-headline text-xs font-bold tracking-[0.28em] text-cyan-400 uppercase">
            {theProblem.kicker}
          </p>
          <h3
            class="mb-6 font-headline text-3xl font-black tracking-tight text-on-primary md:text-4xl">
            {theProblem.title}
          </h3>
          <ul class="max-w-2xl space-y-3">
            {
              (theProblem.painPoints ?? []).map((point: string) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-cyan-400" />
                  <span class="text-base leading-relaxed text-surface-container-highest md:text-lg">
                    {point}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {
            (theProblem.signals ?? []).map(
              (signal: { value: string; label: string }) => (
                <article class="rounded-2xl border border-white/20 bg-white/5 px-5 py-4 backdrop-blur-xs">
                  <p class="font-headline text-2xl font-extrabold tracking-tight text-on-primary">
                    {signal.value}
                  </p>
                  <p class="mt-1 text-sm leading-relaxed text-surface-container-highest">
                    {signal.label}
                  </p>
                </article>
              ),
            )
          }
        </div>
      </div>
    </div>

    <div
      class="mb-24 flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
      <div class="max-w-2xl">
        <h2
          data-reveal="architecture-title"
          class="mb-6 font-headline text-4xl font-extrabold tracking-tighter text-primary md:text-5xl">
          {architecture.title}
        </h2>
        <div class="h-1 w-24 bg-secondary"></div>
      </div>
      <p
        data-reveal="architecture-copy"
        class="max-w-sm font-medium text-on-surface-variant max-lg:text-sm">
        {architecture.description}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3">
      {
        architecture.pillars.map(
          (pillar: { number: string; title: string; description: string }) => (
            <div data-reveal="pillar">
              <NumberedFeatureCard
                number={pillar.number}
                title={pillar.title}
                description={pillar.description}
              />
            </div>
          ),
        )
      }
    </div>
  </LimitContainer>
</section>
