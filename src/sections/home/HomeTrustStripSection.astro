---
import LimitContainer from "@/components/common/LimitContainer.jsx";

const { trust } = Astro.props;
---

<section class="bg-surface-container-high py-12" aria-label="Empresas aliadas">
  <LimitContainer
    className="flex flex-wrap items-center justify-between gap-8 px-6 opacity-40 grayscale lg:px-8">
    {
      trust.logos.map((logo) => (
        <p class="font-headline text-xl font-black tracking-widest">{logo}</p>
      ))
    }
  </LimitContainer>
</section>
