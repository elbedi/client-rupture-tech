---
import "@/styles/global.css";
import siteConfig from "@/config/siteConfig.js";
import Head from "@/layouts/partials/head.jsx";
import site from "@/content/site";
import Header from "@/layouts/partials/header.jsx";
import Footer from "@/layouts/partials/footer.jsx";
import LenisClientInit from "@/components/common/LenisClientInit.jsx";
import WhatsApp from "@/components/common/whatsApp.jsx";
import ContactModalClient from "@/components/common/ContactModalClient.jsx";

const {
  title = siteConfig.title,
  description = siteConfig.description,
  keywords = siteConfig.keywords,
  ogImage,
  ogImageAlt,
  ogType = "website",
  noindex = false,
  bodyClass = "font-sans antialiased selection:bg-white/10 bg-surface font-body text-on-surface",
  headerLinks,
  brandHref = "/",
  extraSchema = [],
} = Astro.props;

const canonical = Astro.url?.toString() || siteConfig.url;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.siteName,
  url: siteConfig.url,
  email: site.email,
  telephone: site.phone,
  logo: {
    "@type": "ImageObject",
    url: `${siteConfig.url}/images/text-logo.png`,
  },
  address: {
    "@type": "PostalAddress",
    addressCountry: "MX",
  },
  sameAs: ["https://www.linkedin.com/company/rupture-technologies"],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.siteName,
  url: siteConfig.url,
  inLanguage: siteConfig.lang,
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description: description,
  url: canonical,
  inLanguage: siteConfig.lang,
  isPartOf: { "@type": "WebSite", url: siteConfig.url },
};

const allSchema = [
  organizationSchema,
  websiteSchema,
  webPageSchema,
  ...extraSchema,
];
---

<!doctype html>
<html lang={siteConfig.lang}>
  <Head
    title={title}
    description={description}
    canonical={canonical}
    keywords={keywords}
    ogImage={ogImage}
    ogImageAlt={ogImageAlt}
    ogType={ogType}
    noindex={noindex}
    schema={allSchema}
  />
  <body class={bodyClass}>
    <div id="site-preloader" aria-hidden="true">
      <img
        src="/images/logo.png"
        alt=""
        decoding="async"
        style="width: 90%; max-width: 300px;"
      />
    </div>
    <script is:inline>
      (() => {
        const body = document.body;
        const preloader = document.getElementById("site-preloader");
        const reduceMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );
        const minimumVisibleTime = 1500;
        const startTime = performance.now();

        if (!preloader || !body) {
          return;
        }

        body.classList.add("preloader-is-active");

        const closePreloader = () => {
          const elapsed = performance.now() - startTime;
          const remaining = Math.max(0, minimumVisibleTime - elapsed);

          window.setTimeout(() => {
            preloader.classList.add("is-hidden");
            body.classList.remove("preloader-is-active");

            window.setTimeout(
              () => {
                preloader.remove();
              },
              reduceMotion.matches ? 0 : 420,
            );
          }, remaining);
        };

        if (document.readyState === "complete") {
          closePreloader();
        } else {
          window.addEventListener("load", closePreloader, { once: true });
        }
      })();
    </script>
    <Header
      brand={site.name}
      brandHref={brandHref}
      links={headerLinks}
      ctaLabel={site.ctaText}
      client:load
    />
    <slot />
    <Footer brand={site.name} email={site.email} phone={site.phone} />
    <ContactModalClient client:load />
    <WhatsApp phone={site.phone} client:load />
    <LenisClientInit client:load />
  </body>
</html>
